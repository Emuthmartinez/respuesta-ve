# Supabase — fill these in after provisioning the project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used to hash request IPs for rate limiting.
# Generate with: openssl rand -hex 32
REPORT_IP_SALT=

# Optional: required only for the token-gated PFIF ingestion route.
INGEST_TOKEN=

# Map tiles. Default uses a free demo style; swap for a production key
# (MapTiler / Protomaps) before heavy traffic.
NEXT_PUBLIC_MAP_STYLE=https://demotiles.maplibre.org/style.json
